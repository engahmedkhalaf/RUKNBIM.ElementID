<Window x:Class="RUKNBIM.ElementID.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RUKNBIM API License Manager" 
        Height="420" Width="680"
        Background="#0E1626"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStyle="ToolWindow"
        FontFamily="Segoe UI">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Grid Grid.Column="0" Background="#070A13">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Sidebar Header -->
            <StackPanel Grid.Row="0" Margin="20,25,20,25">
                <TextBlock Text="RUKNBIM API" Foreground="White" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="Construction Solutions" Foreground="#3A86FF" FontSize="11" FontWeight="SemiBold" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- Sidebar Navigation Menu -->
            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                <!-- Get License -->
                <Grid x:Name="MenuGetLicense" Background="#141C2F" MouseLeftButtonDown="Menu_Click" Cursor="Hand" Tag="0" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle x:Name="IndicatorGetLicense" Grid.Column="0" Fill="#3A86FF" Visibility="Visible"/>
                    <TextBlock x:Name="TextGetLicense" Grid.Column="1" Text="Get License" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="16,10"/>
                </Grid>

                <!-- Activate License -->
                <Grid x:Name="MenuActivateLicense" Background="Transparent" MouseLeftButtonDown="Menu_Click" Cursor="Hand" Tag="1" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle x:Name="IndicatorActivateLicense" Grid.Column="0" Fill="#3A86FF" Visibility="Collapsed"/>
                    <TextBlock x:Name="TextActivateLicense" Grid.Column="1" Text="Activate License" Foreground="Gray" FontSize="13" FontWeight="SemiBold" Margin="16,10"/>
                </Grid>

                <!-- License Status -->
                <Grid x:Name="MenuLicenseStatus" Background="Transparent" MouseLeftButtonDown="Menu_Click" Cursor="Hand" Tag="2" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle x:Name="IndicatorLicenseStatus" Grid.Column="0" Fill="#3A86FF" Visibility="Collapsed"/>
                    <TextBlock x:Name="TextLicenseStatus" Grid.Column="1" Text="License Status" Foreground="Gray" FontSize="13" FontWeight="SemiBold" Margin="16,10"/>
                </Grid>

                <!-- Information -->
                <Grid x:Name="MenuInformation" Background="Transparent" MouseLeftButtonDown="Menu_Click" Cursor="Hand" Tag="3" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle x:Name="IndicatorInformation" Grid.Column="0" Fill="#3A86FF" Visibility="Collapsed"/>
                    <TextBlock x:Name="TextInformation" Grid.Column="1" Text="Information" Foreground="Gray" FontSize="13" FontWeight="SemiBold" Margin="16,10"/>
                </Grid>
            </StackPanel>

            <!-- Sidebar Footer -->
            <StackPanel Grid.Row="2" Margin="20,0,20,20">
                <TextBlock Text="About" Foreground="Gray" FontSize="10" FontWeight="Bold"/>
                <TextBlock Text="Version: 1.0.0" Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
                <TextBlock Text="© RUKNBIM API" Foreground="Gray" FontSize="10" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- RIGHT CONTENT PANEL -->
        <Grid Grid.Column="1" Margin="30,25">
            <!-- 1. GET LICENSE VIEW -->
            <Grid x:Name="TabGetLicense" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="GET PRODUCT LICENSE" Foreground="#3A86FF" FontSize="16" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Text="Acquire a license to activate the RUKNBIM API features." Foreground="White" FontSize="12" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="2" Text="Select an option below to start your trial or request assistance:" Foreground="Gray" FontSize="11" Margin="0,15,0,0"/>

                <StackPanel Grid.Row="3" Margin="0,15,0,0" VerticalAlignment="Top">
                    <!-- Start 7-Day Trial -->
                    <Button x:Name="BtnStartTrial" Height="36" Background="#3A86FF" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Margin="0,6" Click="StartTrial_Click">
                        <Button.Content>Start Free 7-Day Trial</Button.Content>
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                        </Button.Resources>
                    </Button>

                    <!-- Request Code -->
                    <Button Height="36" Background="#141C2F" Foreground="White" BorderBrush="Gray" BorderThickness="1" FontWeight="SemiBold" Cursor="Hand" Margin="0,6" Click="RequestCode_Click">
                        <Button.Content>Request Activation Code (Email)</Button.Content>
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                        </Button.Resources>
                    </Button>

                    <!-- Purchase -->
                    <Button Height="36" Background="#141C2F" Foreground="White" BorderBrush="Gray" BorderThickness="1" FontWeight="SemiBold" Cursor="Hand" Margin="0,6" Click="Purchase_Click">
                        <Button.Content>Purchase Subscription License</Button.Content>
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 2. ACTIVATE LICENSE VIEW -->
            <Grid x:Name="TabActivateLicense" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ACTIVATE LICENSE" Foreground="#3A86FF" FontSize="16" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Text="Sign in with your RUKNBIM credentials to validate your license." Foreground="White" FontSize="12" Margin="0,4,0,0"/>

                <StackPanel Grid.Row="2" Margin="0,20,0,0" VerticalAlignment="Top">
                    <!-- Email -->
                    <TextBlock Text="Email Address" Foreground="LightGray" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="EmailInput" Height="28" Background="#141C2F" Foreground="White" BorderBrush="#3A86FF" BorderThickness="1" 
                             Padding="6,3" VerticalContentAlignment="Center" CaretBrush="White" Margin="0,0,0,12"/>

                    <!-- Password -->
                    <TextBlock Text="Password" Foreground="LightGray" FontSize="11" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PasswordInput" Height="28" Background="#141C2F" Foreground="White" BorderBrush="#3A86FF" BorderThickness="1" 
                                 Padding="6,3" VerticalContentAlignment="Center" CaretBrush="White" Margin="0,0,0,15"/>

                    <!-- Status Label -->
                    <TextBlock x:Name="StatusText" Text="" Foreground="#FF3B30" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,15" Height="32"/>

                    <!-- Activate Button -->
                    <Button x:Name="ActivateButton" Height="34" Background="#3A86FF" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Click="ActivateButton_Click">
                        <Button.Content>Activate License</Button.Content>
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 3. LICENSE STATUS VIEW -->
            <Grid x:Name="TabLicenseStatus" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="LICENSE STATUS" Foreground="#3A86FF" FontSize="16" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Text="View your active software licensing profile details below." Foreground="White" FontSize="12" Margin="0,4,0,0"/>

                <Grid Grid.Row="2" Margin="0,25,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" Foreground="Gray" FontSize="12" Margin="0,6"/>
                    <TextBlock x:Name="StatusValText" Grid.Row="0" Grid.Column="1" Text="Not Activated" Foreground="#FF3B30" FontSize="12" FontWeight="Bold" Margin="0,6"/>

                    <!-- Email -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Licensed Email:" Foreground="Gray" FontSize="12" Margin="0,6"/>
                    <TextBlock x:Name="EmailValText" Grid.Row="1" Grid.Column="1" Text="N/A" Foreground="White" FontSize="12" Margin="0,6"/>

                    <!-- License Type -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="License Type:" Foreground="Gray" FontSize="12" Margin="0,6"/>
                    <TextBlock x:Name="TypeValText" Grid.Row="2" Grid.Column="1" Text="N/A" Foreground="White" FontSize="12" Margin="0,6"/>

                    <!-- Trial Ends -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Expiration Date:" Foreground="Gray" FontSize="12" Margin="0,6"/>
                    <TextBlock x:Name="ExpiryValText" Grid.Row="3" Grid.Column="1" Text="N/A" Foreground="White" FontSize="12" Margin="0,6"/>

                    <!-- Logout Button -->
                    <Button x:Name="DeactivateButton" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Height="32" Background="#FF3B30" Foreground="White" BorderThickness="0" 
                            FontWeight="Bold" Cursor="Hand" VerticalAlignment="Bottom" Margin="0,0,0,10" Click="DeactivateButton_Click">
                        <Button.Content>Deactivate / Sign Out</Button.Content>
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Grid>

            <!-- 4. INFORMATION VIEW -->
            <Grid x:Name="TabInformation" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="PRODUCT INFORMATION" Foreground="#3A86FF" FontSize="16" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Text="Developer details and support channels." Foreground="White" FontSize="12" Margin="0,4,0,0"/>

                <StackPanel Grid.Row="2" Margin="0,20,0,0" VerticalAlignment="Top">
                    <TextBlock Text="Prepared by: Ahmed Khalaf (BIM Manager)" Foreground="LightGray" FontSize="13" Margin="0,4"/>
                    <TextBlock Text="Mobile: +966542554127" Foreground="LightGray" FontSize="13" Margin="0,4"/>
                    
                    <!-- Support -->
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Contact Support: " Foreground="LightGray" FontSize="13"/>
                        <TextBlock Text="engkhalaf7@gmail.com" Foreground="#3A86FF" FontSize="13" Cursor="Hand" TextDecorations="Underline" MouseDown="SupportLink_Click"/>
                    </StackPanel>

                    <!-- Website -->
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Website: " Foreground="LightGray" FontSize="13"/>
                        <TextBlock Text="rukn-bim-website-opka.vercel.app" Foreground="#3A86FF" FontSize="13" Cursor="Hand" TextDecorations="Underline" MouseDown="WebLink_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
