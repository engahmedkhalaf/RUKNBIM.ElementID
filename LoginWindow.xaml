<Window x:Class="RUKNBIM.ElementID.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RUKNBIM Smart Select Activation" 
        Height="340" Width="380"
        Background="#0B132B"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStyle="ToolWindow"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Logo / Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15" HorizontalAlignment="Center">
            <TextBlock Text="RUKNBIM" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Smart Select Activation" Foreground="#3A86FF" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Email Field -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Email Address" Foreground="LightGray" FontSize="11" Margin="0,0,0,4"/>
            <TextBox x:Name="EmailInput" Height="28" Background="#1C2541" Foreground="White" BorderBrush="#3A86FF" BorderThickness="1" 
                     Padding="5,3" VerticalContentAlignment="Center" CaretBrush="White"/>
        </StackPanel>

        <!-- Password Field -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Password" Foreground="LightGray" FontSize="11" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordInput" Height="28" Background="#1C2541" Foreground="White" BorderBrush="#3A86FF" BorderThickness="1" 
                         Padding="5,3" VerticalContentAlignment="Center" CaretBrush="White"/>
        </StackPanel>

        <!-- Status / Error Message -->
        <TextBlock x:Name="StatusText" Grid.Row="3" Text="" Foreground="#FF3B30" FontSize="11" TextWrapping="Wrap" 
                   HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12" Height="32"/>

        <!-- Action Buttons -->
        <Button x:Name="ActivateButton" Grid.Row="4" Content="Activate License" Height="32" Background="#3A86FF" Foreground="White" 
                FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="ActivateButton_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="3"/>
                </Style>
            </Button.Resources>
        </Button>

        <!-- Footer Info -->
        <TextBlock Grid.Row="5" HorizontalAlignment="Center" VerticalAlignment="Bottom" FontSize="10" Foreground="Gray">
            Need an account? Contact <Run Text="engkhalaf7@gmail.com" Foreground="#3A86FF"/>
        </TextBlock>
    </Grid>
</Window>
